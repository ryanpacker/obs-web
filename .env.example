# WorkOS (server-side, secret)
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_REDIRECT_URI=https://your-domain/auth/callback
SESSION_SECRET=<random-32-byte-hex>

# OBS WebSocket (server-side, secret)
OBS_WS_PASSWORD=your-obs-websocket-password

# Convex (client-side, public)
PUBLIC_CONVEX_URL=https://useful-pika-111.convex.cloud
